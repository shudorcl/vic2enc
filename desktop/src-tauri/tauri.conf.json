{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vic2 编码转换",
  "version": "0.1.0",
  "identifier": "com.vic2encoding.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vic2 编码转换工具",
        "width": 760,
        "height": 680,
        "minWidth": 560,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
